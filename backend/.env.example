# Server
PORT=3101
HOST=0.0.0.0
TRUST_PROXY=false

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=vehicle_control
DATABASE_USER=postgres
DATABASE_PASSWORD=change_me

# JWT (min 16 characters, must NOT be a common word or placeholder)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
JWT_SECRET=
JWT_EXPIRES_IN=8h

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (required in production)
# Comma-separated frontend origins allowed by CORS and WebSocket CORS
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Superadmin seed account
SUPERADMIN_FIRST_NAME=Super
SUPERADMIN_LAST_NAME=Administrador
SUPERADMIN_GRADE=N/A
SUPERADMIN_PHONE=0000000000
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=Sup3r@dmin!2026#Vehicular

# Storage
# local = guarda archivos en /uploads
# r2 = guarda archivos en Cloudflare R2
STORAGE_DRIVER=local

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=